function oscillationSeverity = computeOscillationSeverity(x)
    % COMPUTEOSCILLATIONSEVERITY Sums magnitude of first difference in x as proxy for oscillation severity.
    %
    % AUTHOR: Cole H. Shaigec
    %
    % INPUT
    %  x (numTimestamps x 2 double) - simulated state trajectory
    %
    % OUTPUT
    %  oscillationSeverity (double)

    firstDifferenceInX
end

% Summing some kind of absolute deviation is probably the right move here